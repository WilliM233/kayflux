{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "wwe-universe-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "desktop-ui-preview",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const h=require('http'),f=require('fs'),p=require('path'),m={'html':'text/html','css':'text/css','js':'application/javascript'};h.createServer((q,r)=>{let u=q.url==='/'?'/index.html':q.url;let fp=p.join('desktop/src',u);f.readFile(fp,(e,d)=>{if(e){r.writeHead(404);r.end('Not found');}else{r.writeHead(200,{'Content-Type':m[p.extname(fp).slice(1)]||'text/plain'});r.end(d);}});}).listen(3001)"],
      "port": 3001
    }
  ]
}
